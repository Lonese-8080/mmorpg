{
  "TcpServer": {
    "Host": "0.0.0.0",
    "Port": 7001,
    "Backlog": 512,
    "MaxConnections": 10000,
    "ReceiveBufferSize": 8192,
    "SendBufferSize": 8192,
    "EnableResizableBuffer": true,
    "EnableHybridBuffer": true,
    "HybridBufferSize": 65536
  },
  "Security": {
    "EnableEncryption": true,
    "EnableCompression": true,
    "CompressionThreshold": 1024,
    "MasterKey": "ChangeThisInProduction1234567890ABCDEF"
  },
  "RateLimiting": {
    "EnableGlobalLimit": true,
    "GlobalLimitPerSecond": 100000,
    "EnablePerConnectionLimit": true,
    "PerConnectionLimitPerSecond": 1000
  },
  "Resilience": {
    "EnableCircuitBreaker": true,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerDurationOfBreakMs": 30000,
    "EnableRetry": true,
    "RetryMaxAttemptCount": 3,
    "RetryBaseDelayMs": 200,
    "EnableTimeout": true,
    "TimeoutMs": 5000
  },
  "HealthCheck": {
    "Port": 8080,
    "EnableDetailedHealth": true
  },
  "Metrics": {
    "Enable": true,
    "Port": 9090
  },
  "Tracing": {
    "Enable": true,
    "ServiceName": "MMORPG-GameServer",
    "OtlpEndpoint": "http://jaeger:4317"
  }
}
