{
  "SchemaVersion": "1.0.0",
  "Server": {
    "ServerId": 1,
    "ServerName": "MMORPG Production Server",
    "Type": "Game",
    "DebugMode": false
  },
  "Performance": {
    "TargetFps": 60,
    "MaxFps": 120,
    "MinFps": 30,
    "MaxQueueLength": 10000
  },
  "Logging": {
    "MinLevel": "Info",
    "EnableConsole": true,
    "EnableFile": true,
    "LogDirectory": "logs",
    "RetentionDays": 30,
    "SamplingRate": 0.3,
    "SuppressDuplicateThresholdMs": 5000,
    "EnableNetwork": false,
    "NetworkEndpoint": null
  },
  "Network": {
    "Port": 9000,
    "Backlog": 512,
    "MaxConnections": 10000,
    "HeartbeatInterval": 5,
    "HeartbeatTimeout": 20,
    "ReceiveBufferSize": 8192,
    "SendBufferSize": 8192,
    "EnableTls": true,
    "CertificatePath": "certs/server.pfx",
    "CertificatePassword": "",
    "EnableCertificateHotReload": true,
    "SessionMessageRateLimit": 200,
    "GlobalMessageRateLimit": 20000,
    "MessageRetryCount": 3,
    "MessageRetryIntervalMs": 100,
    "SessionPool": {
      "MinPoolSize": 200,
      "MaxPoolSize": 2000,
      "MaxIdleCapacity": 1000,
      "EnablePool": true
    }
  },
  "Database": {
    "Type": "MySql",
    "ConnectionString": "",
    "MaxPoolSize": 100,
    "MinPoolSize": 10,
    "ConnectionTimeout": 30,
    "CommandTimeout": 30
  },
  "Observability": {
    "EnableMetrics": true,
    "EnableHealthCheck": true,
    "EnableMemoryMonitor": true,
    "EnableCrashReporting": true,
    "MemoryWarningThresholdMB": 1024,
    "MemoryCriticalThresholdMB": 2048,
    "MemoryCheckIntervalSeconds": 30,
    "EnablePrometheus": true,
    "PrometheusPort": 9091,
    "PrometheusPath": "/metrics"
  }
}
